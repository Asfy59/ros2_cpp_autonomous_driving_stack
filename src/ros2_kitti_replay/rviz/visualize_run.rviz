Panels:
  - Class: rviz_common/Displays
    Help Height: 99
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /Ground Truth Vehicle1/Description Topic1
        - /Odometry Path1/Topic1
        - /Odometry Path1/Offset1
      Splitter Ratio: 0.5
    Tree Height: 459
  - Class: rviz_common/Selection
    Name: Selection
  - Class: rviz_common/Tool Properties
    Expanded:
      - /2D Goal Pose1
      - /Publish Point1
    Name: Tool Properties
    Splitter Ratio: 0.5886790156364441
  - Class: rviz_common/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
  - Class: rviz_common/Time
    Experimental: false
    Name: Time
    SyncMode: 0
    SyncSource: Point Cloud
  - Class: ros2_kitti_rviz_plugin/ReplayPanel
    Name: ReplayPanel
